    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.101.1",
    "class-variance-authority": "^0.7.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "prettier": "^3.8.5",
    "react": "19.2.4",
